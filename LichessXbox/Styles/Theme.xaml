<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:LichessXbox.Helpers">

    <helpers:BoolToOpacityConverter x:Key="BoolToOpacity" />
    <helpers:CurrentMoveBrushConverter x:Key="CurrentMoveBrush" />

    <!-- ============ Palette ============ -->
    <!-- Warm "tournament" dark, inspired by lichess board tones -->
    <Color x:Key="AppBackgroundColor">#14110D</Color>
    <Color x:Key="AppSurfaceColor">#1F1B15</Color>
    <Color x:Key="AppSurfaceHighColor">#2A251D</Color>
    <Color x:Key="AccentGreenColor">#6FA630</Color>
    <Color x:Key="AccentGreenLightColor">#8FCB3F</Color>
    <Color x:Key="TextPrimaryColor">#F4F1EA</Color>
    <Color x:Key="TextSecondaryColor">#A8A296</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="AppSurfaceHighBrush" Color="{StaticResource AppSurfaceHighColor}" />
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="AccentGreenLightBrush" Color="{StaticResource AccentGreenLightColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#E0795E" />
    <SolidColorBrush x:Key="LiveBrush" Color="#E0463A" />
    <SolidColorBrush x:Key="ClockChipBrush" Color="#22000000" />

    <!-- Green the "on" state of every ToggleSwitch (default is system blue) so toggles
         match the app's green accent. Overriding these well-known theme keys app-wide. -->
    <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="{StaticResource AccentGreenLightColor}" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="{StaticResource AccentGreenLightColor}" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="{StaticResource AccentGreenLightColor}" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="{StaticResource AccentGreenLightColor}" />

    <!-- Text boxes themed to the warm dark surface. The default UWP TextBox is a near-white
         box with dark text, which looked out of place; these well-known theme keys recolor
         every TextBox (background, text, border, placeholder, selection) to match the app. -->
    <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource AppSurfaceHighColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource AppSurfaceHighColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource AppSurfaceHighColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="{StaticResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="{StaticResource AccentGreenColor}" />

    <!-- Hero gradient used behind the home / login screens -->
    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1B2410" Offset="0.0" />
        <GradientStop Color="#14110D" Offset="0.55" />
        <GradientStop Color="#241A0E" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentGreenColor}" Offset="0.0" />
        <GradientStop Color="{StaticResource AccentGreenLightColor}" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ============ Type ramp (tuned for 10ft viewing) ============ -->
    <x:Double x:Key="DisplaySize">64</x:Double>
    <x:Double x:Key="TitleSize">36</x:Double>
    <x:Double x:Key="SubtitleSize">24</x:Double>
    <x:Double x:Key="BodySize">20</x:Double>
    <x:Double x:Key="CaptionSize">16</x:Double>

    <!-- ============ Card style ============ -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="28" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
    </Style>

    <!-- ============ Big focusable menu/action button ============ -->
    <Style x:Key="TileButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AppSurfaceHighBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="24,16" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="{StaticResource BodySize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="Scale" CenterX="0" CenterY="0" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <!-- Base fill (per-instance brush via TemplateBinding, never mutated) -->
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16" />
                        <!-- Hover tint: animate opacity, not a shared brush's colour -->
                        <Border x:Name="HoverTint" CornerRadius="16" Opacity="0">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.10" />
                            </Border.Background>
                        </Border>
                        <!-- Focus ring: its own brush, materialised per templated instance.
                             Green to match the rest of the app's focus visuals. -->
                        <Border x:Name="FocusRing" CornerRadius="16" Opacity="0" BorderThickness="3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{StaticResource AccentGreenLightColor}" />
                            </Border.BorderBrush>
                        </Border>
                        <ContentPresenter x:Name="Content"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverTint" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="FocusRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0" />
                                        <DoubleAnimation Storyboard.TargetName="Content" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                            <!-- Gamepad / keyboard focus = the moment that has to feel great on a TV -->
                            <VisualStateGroup x:Name="FocusStates">
                                <!-- Focus = the green ring + hover tint only. No scale: scaling the
                                     focused button made the initially-focused button (nav Home / first
                                     tile) look wider than its peers until focus moved elsewhere. -->
                                <VisualState x:Name="Focused">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="HoverTint" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unfocused" />
                                <VisualState x:Name="PointerFocused" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary call-to-action button (green, filled) -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource TileButton}">
        <Setter Property="Background" Value="{StaticResource AccentGreenBrush}" />
        <Setter Property="Foreground" Value="#0E1207" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Compact navigation-pane button so the full menu fits without being cut off -->
    <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource TileButton}">
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="{StaticResource CaptionSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Chess-board square. No default-button gray; just a tasteful inset green focus
         ring + a soft brighten, so moving the cursor across the board feels premium.
         The square colour comes from the per-cell Background (TemplateBinding). -->
    <Style x:Key="BoardCellButton" TargetType="Button">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" />
                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <!-- soft brighten on hover/press -->
                        <Border x:Name="Sheen" IsHitTestVisible="False" Opacity="0">
                            <Border.Background><SolidColorBrush Color="#FFFFFF" Opacity="0.10" /></Border.Background>
                        </Border>
                        <!-- crisp inset green ring on gamepad/keyboard focus -->
                        <Border x:Name="Ring" IsHitTestVisible="False" Opacity="0" BorderThickness="3" CornerRadius="4" Margin="2">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.10" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.05" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Focused">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="Ring" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.10" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unfocused" />
                                <VisualState x:Name="PointerFocused" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Round/compact icon button (e.g. the nav hamburger). No default-button gray:
         constant fill, a white sheen on press, and the green focus ring. CornerRadius
         is honoured so it can be a circle. -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" />
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <Border x:Name="Sheen" CornerRadius="{TemplateBinding CornerRadius}" IsHitTestVisible="False" Opacity="0">
                            <Border.Background><SolidColorBrush Color="#FFFFFF" Opacity="0.12" /></Border.Background>
                        </Border>
                        <Border x:Name="Ring" CornerRadius="{TemplateBinding CornerRadius}" BorderThickness="2.5" IsHitTestVisible="False" Opacity="0">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.10" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.05" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Focused">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="Ring" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.10" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unfocused" />
                                <VisualState x:Name="PointerFocused" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Combo boxes get the green focus ring to match the rest of the app. UseSystemFocusVisuals
         must be on for the FocusVisual*Brush rectangle to actually be drawn. -->
    <Style x:Key="ThemedComboBox" TargetType="ComboBox">
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{StaticResource AccentGreenLightBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="#99000000" />
    </Style>

    <!-- Every text box and toggle switch gets the app's green focus ring instead of the default
         system/accent visual, so gamepad focus reads consistently across the app. The system
         focus visual must be enabled for the green FocusVisual brush to render. Implicit = app-wide. -->
    <Style TargetType="TextBox">
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{StaticResource AccentGreenLightBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="#99000000" />
    </Style>
    <Style TargetType="ToggleSwitch">
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="FocusVisualPrimaryBrush" Value="{StaticResource AccentGreenLightBrush}" />
        <Setter Property="FocusVisualSecondaryBrush" Value="#99000000" />
    </Style>

    <!-- List/grid item containers get the SAME rounded green focus ring as the tiles
         and nav buttons (not the thin system reveal rect). The container owns the
         spacing margin so the ring hugs each row/tile; item DataTemplates with their
         own background Border therefore drop their outer Margin. Implicit = app-wide. -->
    <Style TargetType="ListViewItem">
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid Background="Transparent">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <Border x:Name="Tint" CornerRadius="12" IsHitTestVisible="False" Opacity="0">
                            <Border.Background><SolidColorBrush Color="#FFFFFF" Opacity="0.08" /></Border.Background>
                        </Border>
                        <!-- One ring per visual-state group so hover/focus/selection don't fight. -->
                        <Border x:Name="HoverRing" CornerRadius="12" BorderThickness="3" IsHitTestVisible="False" Opacity="0">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <Border x:Name="SelRing" CornerRadius="12" BorderThickness="3" IsHitTestVisible="False"
                                Opacity="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToOpacity}}">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <Border x:Name="FocusRing" CornerRadius="12" BorderThickness="3" IsHitTestVisible="False" Opacity="0">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Tint" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Tint" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Focused">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="FocusRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unfocused" />
                                <VisualState x:Name="PointerFocused" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="GridViewItem">
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewItem">
                    <Grid Background="Transparent">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <Border x:Name="Tint" CornerRadius="16" IsHitTestVisible="False" Opacity="0">
                            <Border.Background><SolidColorBrush Color="#FFFFFF" Opacity="0.08" /></Border.Background>
                        </Border>
                        <!-- One ring per visual-state group so hover, focus and selection never
                             fight over a shared property (which left old selections stuck green). -->
                        <Border x:Name="HoverRing" CornerRadius="16" BorderThickness="3" IsHitTestVisible="False" Opacity="0">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <Border x:Name="SelRing" CornerRadius="16" BorderThickness="3" IsHitTestVisible="False"
                                Opacity="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToOpacity}}">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <Border x:Name="FocusRing" CornerRadius="16" BorderThickness="3" IsHitTestVisible="False" Opacity="0">
                            <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Tint" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Tint" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Focused">
                                    <Storyboard><DoubleAnimation Storyboard.TargetName="FocusRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" /></Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unfocused" />
                                <VisualState x:Name="PointerFocused" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
