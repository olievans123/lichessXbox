<Page
    x:Class="LichessXbox.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="48,36">

        <!-- Signed out: personal-token sign-in (reliable on Xbox; no WebView/broker) -->
        <ScrollViewer x:Name="SignedOutCard" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled"
                      Visibility="Collapsed">
            <Border MaxWidth="640" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Style="{StaticResource CardBorder}" Padding="32">
                <StackPanel Spacing="14">
                    <TextBlock Text="Sign in to Lichess" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock TextWrapping="Wrap" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="On your phone or computer, open the link below, create a token (the chess scopes are pre-selected), then enter it here." />
                    <Border Background="#22000000" CornerRadius="8" Padding="14,10">
                        <TextBlock Text="lichess.org/account/oauth/token/create?scopes[]=board:play&amp;scopes[]=puzzle:read&amp;description=Lichess+for+Xbox"
                                   FontSize="14" FontFamily="Consolas" Foreground="{StaticResource AccentGreenLightBrush}" TextWrapping="Wrap" />
                    </Border>
                    <TextBlock Text="Paste your token:" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox x:Name="TokenBox" PlaceholderText="lip_xxxxxxxxxxxxxxxx" FontSize="16"
                             Height="52" VerticalContentAlignment="Center" />
                    <Button x:Name="SignInButton" Style="{StaticResource PrimaryButton}" Click="SignIn_Click"
                            MinWidth="220" HorizontalAlignment="Left" Content="Sign in" />
                    <ProgressRing x:Name="Busy" IsActive="False" Width="32" Height="32"
                                  Foreground="{StaticResource AccentGreenLightBrush}" HorizontalAlignment="Left" />
                    <TextBlock x:Name="StatusText" Foreground="#E0A0A0" FontSize="15"
                               Visibility="Collapsed" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Signed in -->
        <StackPanel x:Name="SignedInPanel" Spacing="28" Visibility="Collapsed" MaxWidth="900">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <Border Width="96" Height="96" CornerRadius="24" Background="{StaticResource AccentGradientBrush}">
                    <TextBlock x:Name="AvatarInitial" Text="?" FontSize="48" FontWeight="Bold" Foreground="#0E1207"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="UsernameText" Text="" FontSize="44" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="SubtitleText" Text="Lichess member" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Ratings" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
            <GridView x:Name="RatingsGrid" SelectionMode="None" IsItemClickEnabled="False">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180" Height="120" CornerRadius="16" Margin="8"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <StackPanel Margin="20" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Mode}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Value}" FontSize="40" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Button x:Name="SignOutButton" Style="{StaticResource TileButton}" Click="SignOut_Click"
                    Content="Sign out" MinWidth="200" HorizontalContentAlignment="Center" HorizontalAlignment="Left" />
        </StackPanel>
    </Grid>
</Page>
