<Page
    x:Class="LichessXbox.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}">

        <!-- Top-level loading state (shown while EnsureAccountAsync runs on entry) -->
        <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Spacing="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Collapsed">
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="30" Height="30"
                          Foreground="{StaticResource AccentGreenLightBrush}" />
            <TextBlock Text="Loading…" FontSize="{StaticResource BodySize}"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Signed out: scan-to-pair by default (token returns to the console automatically) -->
        <ScrollViewer x:Name="SignedOutCard" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled"
                      Visibility="Collapsed">
            <Border MaxWidth="760" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Style="{StaticResource CardBorder}" Padding="32">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Sign in to Lichess" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Scan the code with your phone to connect your account — no typing on the TV."
                                   FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- QR device pairing -->
                    <StackPanel x:Name="QrPanel" Spacing="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="10" VerticalAlignment="Center">
                                <Image x:Name="QrImage" Width="200" Height="200" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="26,0,0,0" VerticalAlignment="Center" Spacing="10">
                                <TextBlock Text="Scan with your phone" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock TextWrapping="Wrap" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="1.  Point your phone's camera at the code&#x0a;2.  Sign in to Lichess and tap approve&#x0a;3.  You're in — nothing to type here" />
                                <TextBlock Text="You only do this once — the console stays signed in afterwards." TextWrapping="Wrap"
                                           FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource AccentGreenLightBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ProgressRing x:Name="QrBusy" IsActive="False" Width="18" Height="18"
                                                  Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" />
                                    <TextBlock x:Name="QrStatus" Text="Preparing…" FontSize="{StaticResource CaptionSize}"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="RefreshQrButton" Style="{StaticResource TileButton}" Click="ShowQr_Click"
                                            Content="↻ New code" Padding="18,10" HorizontalContentAlignment="Center" />
                                    <Button x:Name="ManualToggleButton" Style="{StaticResource TileButton}" Click="ShowManual_Click"
                                            Content="Enter a token" Padding="18,10" HorizontalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Manual token entry (only if selected) -->
                    <StackPanel x:Name="ManualPanel" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="Enter a token" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock TextWrapping="Wrap" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="On your phone or computer, open this link to create a token (chess permissions are pre-selected), then type or paste it below:" />
                        <Border Background="{StaticResource ClockChipBrush}" CornerRadius="10" Padding="14,10">
                            <TextBlock Text="lichess.org/account/oauth/token/create?scopes[]=board:play&amp;scopes[]=challenge:write&amp;scopes[]=puzzle:read&amp;description=Lichess+for+Xbox"
                                       FontSize="{StaticResource CaptionSize}" FontFamily="Consolas" Foreground="{StaticResource AccentGreenLightBrush}" TextWrapping="Wrap" />
                        </Border>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TokenBox" Grid.Column="0" PlaceholderText="lip_xxxxxxxxxxxxxxxx" FontSize="16"
                                     Height="52" VerticalContentAlignment="Center" />
                            <Button x:Name="PasteTokenButton" Grid.Column="1" Style="{StaticResource TileButton}" Click="PasteToken_Click"
                                    Content="Paste" Padding="18,10" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SignInButton" Grid.Column="0" Style="{StaticResource PrimaryButton}" Click="SignIn_Click"
                                    Content="Sign in" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            <Button Grid.Column="1" Style="{StaticResource TileButton}" Click="ShowQr_Click"
                                    Content="Use QR code" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <ProgressRing x:Name="Busy" IsActive="False" Width="30" Height="30"
                                  Foreground="{StaticResource AccentGreenLightBrush}" HorizontalAlignment="Left" />
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource ErrorBrush}" FontSize="{StaticResource CaptionSize}"
                               Visibility="Collapsed" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Signed in -->
        <ScrollViewer x:Name="SignedInScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" Visibility="Collapsed">
        <StackPanel x:Name="SignedInPanel" Spacing="18" Visibility="Collapsed" MaxWidth="760">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <Border Width="72" Height="72" CornerRadius="24" Background="{StaticResource AccentGradientBrush}">
                    <TextBlock x:Name="AvatarInitial" Text="?" FontSize="36" FontWeight="Bold" Foreground="#0E1207"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center" MaxWidth="540">
                    <TextBlock x:Name="UsernameText" Text="" FontSize="{StaticResource TitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="SubtitleText" Text="Lichess member" FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Ratings" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
            <TextBlock x:Name="NoRatings" Text="No rated games yet." FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" />
            <GridView x:Name="RatingsGrid" SelectionMode="None" IsItemClickEnabled="False" ItemClick="Rating_ItemClick" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <!-- Display-only: ratings aren't clickable (no graph/games drill-in) and aren't focus stops. -->
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="IsTabStop" Value="False" />
                        <Setter Property="UseSystemFocusVisuals" Value="False" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="150" Height="100" CornerRadius="16"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                            <StackPanel Margin="20" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Mode}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Value}" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- In-page detail for the selected rating: elo graph + recent games (revealed on click) -->
            <StackPanel x:Name="RatingDetailPanel" Spacing="14" Visibility="Collapsed">
                <Border Style="{StaticResource CardBorder}" Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="RatingDetailTitle" Text="Rating" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenLightBrush}" />
                        <Border Height="170" CornerRadius="10" Background="{StaticResource SurfaceSunkenBrush}">
                            <Canvas x:Name="ProfileGraph" />
                        </Border>
                        <TextBlock x:Name="ProfileRatingRange" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="Recent games" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                <ProgressRing x:Name="ProfileGamesBusy" IsActive="False" Width="26" Height="26"
                              Foreground="{StaticResource AccentGreenLightBrush}" HorizontalAlignment="Left" />
                <TextBlock x:Name="ProfileNoGames" Text="" FontSize="{StaticResource CaptionSize}"
                           Foreground="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" />
                <ListView x:Name="ProfileGames" SelectionMode="None" IsItemClickEnabled="True" ItemClick="ProfileGame_ItemClick"
                          ScrollViewer.VerticalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="18,14" Margin="0,0,0,8"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Headline}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ResultText}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Replay" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentGreenLightBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <Button x:Name="SignOutButton" Style="{StaticResource TileButton}" Click="SignOut_Click"
                    Content="Sign out" MinWidth="160" HorizontalContentAlignment="Center" HorizontalAlignment="Left" />
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
