<Page
    x:Class="LichessXbox.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="48,36">

        <!-- Signed out -->
        <Border x:Name="SignedOutCard" MaxWidth="620" VerticalAlignment="Center" HorizontalAlignment="Center"
                Style="{StaticResource CardBorder}" Padding="48" Visibility="Collapsed">
            <StackPanel Spacing="22" HorizontalAlignment="Center">
                <Border Width="84" Height="84" CornerRadius="20" Background="{StaticResource AccentGradientBrush}" HorizontalAlignment="Center">
                    <TextBlock Text="♞" FontFamily="Segoe UI Symbol" FontSize="56" Foreground="#0E1207"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Sign in to Lichess" FontSize="34" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="18"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Connect your free lichess.org account to play. Secure OAuth — your password is never seen by this app." />
                <Button x:Name="SignInButton" Style="{StaticResource PrimaryButton}" Click="SignIn_Click"
                        MinWidth="280" HorizontalAlignment="Center" Content="Sign in with Lichess" />
                <ProgressRing x:Name="Busy" IsActive="False" Width="36" Height="36" Foreground="{StaticResource AccentGreenLightBrush}" />
                <TextBlock x:Name="StatusText" Foreground="#E0A0A0" FontSize="16" HorizontalAlignment="Center"
                           Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Signed in -->
        <StackPanel x:Name="SignedInPanel" Spacing="28" Visibility="Collapsed" MaxWidth="900">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <Border Width="96" Height="96" CornerRadius="24" Background="{StaticResource AccentGradientBrush}">
                    <TextBlock x:Name="AvatarInitial" Text="?" FontSize="48" FontWeight="Bold" Foreground="#0E1207"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="UsernameText" Text="" FontSize="44" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="SubtitleText" Text="Lichess member" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Ratings" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
            <GridView x:Name="RatingsGrid" SelectionMode="None" IsItemClickEnabled="False">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180" Height="120" CornerRadius="16" Margin="8"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <StackPanel Margin="20" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Mode}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Value}" FontSize="40" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Button x:Name="SignOutButton" Style="{StaticResource TileButton}" Click="SignOut_Click"
                    Content="Sign out" MinWidth="200" HorizontalContentAlignment="Center" HorizontalAlignment="Left" />
        </StackPanel>
    </Grid>
</Page>
