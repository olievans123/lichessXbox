<Page
    x:Class="LichessXbox.Views.TvPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="40,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0" Stretch="Uniform">
            <controls:ChessBoardControl x:Name="Board" Interactive="False" Width="760" Height="760" />
        </Viewbox>

        <StackPanel Grid.Column="1" Margin="32,0,0,0" Spacing="16" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="14" Height="14" CornerRadius="7" Background="{StaticResource LiveBrush}" VerticalAlignment="Center" />
                <TextBlock Text="LIVE · Lichess TV" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>

            <Border Style="{StaticResource CardBorder}" Padding="20">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="TopName" Text="—" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="TopRating" Text="" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{StaticResource ClockChipBrush}" CornerRadius="10" Padding="16,8">
                        <TextBlock x:Name="TopClock" Text="--:--" FontSize="28" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="20">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="BottomName" Text="—" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="BottomRating" Text="" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{StaticResource ClockChipBrush}" CornerRadius="10" Padding="16,8">
                        <TextBlock x:Name="BottomClock" Text="--:--" FontSize="28" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Border>
                </Grid>
            </Border>

            <TextBlock Text="The best game in progress on Lichess, updated live."
                       FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
