<Page
    x:Class="LichessXbox.Views.WatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="440" />
        </Grid.ColumnDefinitions>

        <!-- Board + players -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock x:Name="TopName" Text="—" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="TopRating" Text="" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <Border HorizontalAlignment="Right" Background="#22000000" CornerRadius="10" Padding="14,6">
                    <TextBlock x:Name="TopClock" Text="--:--" FontSize="26" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>
            </Grid>

            <Viewbox Grid.Row="1" Stretch="Uniform">
                <controls:ChessBoardControl x:Name="Board" Interactive="False" Width="720" Height="720" />
            </Viewbox>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock x:Name="BottomName" Text="—" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="BottomRating" Text="" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <Border HorizontalAlignment="Right" Background="#22000000" CornerRadius="10" Padding="14,6">
                    <TextBlock x:Name="BottomClock" Text="--:--" FontSize="26" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>
            </Grid>
        </Grid>

        <!-- Channels / streamers / broadcasts -->
        <ScrollViewer Grid.Column="1" Margin="28,0,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="16" Padding="0,0,10,16">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="14" Height="14" CornerRadius="7" Background="#E0463A" VerticalAlignment="Center" />
                    <TextBlock x:Name="HeaderText" Text="Lichess TV" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <TextBlock Text="Channels" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                <ListView x:Name="ChannelList" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="Channel_ItemClick" MaxHeight="360">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontSize="24" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Featured}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Text="Live streamers" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                <ItemsControl x:Name="StreamerList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,8"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="#22FFFFFF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Status}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Simuls" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                <ItemsControl x:Name="SimulList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,8"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="#22FFFFFF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Info}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Broadcasts" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                <ItemsControl x:Name="BroadcastList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,8"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="#22FFFFFF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
