<Page
    x:Class="LichessXbox.Views.TournamentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <!-- List -->
        <Grid Grid.Column="0" Margin="0,0,28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                <TextBlock Text="Tournaments" FontSize="{StaticResource TitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Live and upcoming arenas on Lichess." FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
            <ListView Grid.Row="1" x:Name="TournamentList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Tournament_ItemClick" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="18,14"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Info}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Background="{StaticResource HairlineBrush}" CornerRadius="8" Padding="10,4">
                                    <TextBlock Text="{Binding Group}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource AccentGreenLightBrush}" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ProgressRing Grid.Row="1" x:Name="Busy" IsActive="False" Width="40" Height="40"
                          Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0" />
            <TextBlock Grid.Row="1" x:Name="ListStatus" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0" />
            <Button Grid.Row="1" x:Name="RetryButton" Style="{StaticResource TileButton}" Click="Retry_Click"
                    Content="Refresh" HorizontalAlignment="Center" HorizontalContentAlignment="Center" MinWidth="160"
                    VerticalAlignment="Top" Margin="0,80,0,0" Visibility="Collapsed" />
        </Grid>

        <!-- Detail -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="DetailTitle" Text="Select a tournament" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                <Button Grid.Row="1" x:Name="JoinButton" Style="{StaticResource PrimaryButton}" Click="Join_Click"
                        Content="Join" MinWidth="160" Margin="0,14" Visibility="Collapsed" HorizontalAlignment="Left" />
                <!-- Status gets its OWN row (it used to share the standings row and drew on top of
                     rank #1). The ring spins while we wait for the arena to pair us. -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ProgressRing Grid.Column="0" x:Name="PairRing" IsActive="False" Visibility="Collapsed" Width="20" Height="20"
                                  Margin="0,8,10,0" VerticalAlignment="Top" Foreground="{StaticResource AccentGreenLightBrush}" />
                    <TextBlock Grid.Column="1" x:Name="DetailStatus" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="Collapsed" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,8,0,0" />
                </Grid>
                <!-- Informational only: clickable (so a gamepad can focus + scroll it) but never
                     "selected", so no persistent green selection ring lingers on a row. -->
                <ListView Grid.Row="3" x:Name="StandingsList" SelectionMode="None" IsItemClickEnabled="True"
                          Padding="0,0,0,12" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                    <!-- Read-only standings: focusable for gamepad scrolling, but no focus ring (nothing to click). -->
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="UseSystemFocusVisuals" Value="False" />
                            <!-- Stretch each row to the full width so the * name column expands and the score right-aligns. -->
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="2,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding RankText}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding RatingText}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding ScoreText}" FontSize="{StaticResource BodySize}" Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
