<Page
    x:Class="LichessXbox.Views.PuzzlesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="40,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0" Stretch="Uniform">
            <controls:ChessBoardControl x:Name="Board" Interactive="True" />
        </Viewbox>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
        <StackPanel Margin="24,0,0,0" Padding="0,0,10,16" Spacing="12" VerticalAlignment="Top">
            <TextBlock Text="Puzzles" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="ModeTraining" Grid.Column="0" Style="{StaticResource NavButton}" Tag="training" Click="Mode_Click"
                        Content="Training" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Button x:Name="ModeStreak" Grid.Column="1" Style="{StaticResource NavButton}" Tag="streak" Click="Mode_Click"
                        Content="Streak" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Button x:Name="ModeThemed" Grid.Column="2" Style="{StaticResource NavButton}" Tag="themed" Click="Mode_Click"
                        Content="Themed" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
            </Grid>

            <ComboBox x:Name="ThemeBox" Visibility="Collapsed" HorizontalAlignment="Stretch" Style="{StaticResource ThemedComboBox}" FontSize="{StaticResource CaptionSize}"
                      Header="Theme" SelectionChanged="ThemeBox_SelectionChanged" />

            <Border x:Name="StreakCard" Visibility="Collapsed" Style="{StaticResource CardBorder}" Padding="16,10">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="🔥" FontSize="28" />
                    <StackPanel>
                        <TextBlock Text="Current streak" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="StreakText" Text="0" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="ToMoveText" Text="" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGreenLightBrush}" />
                    <TextBlock x:Name="HintText" Text="Find the best move." FontSize="{StaticResource BodySize}"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Spacing="4" Margin="0,6,0,0">
                        <TextBlock x:Name="RatingText" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="ThemesText" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="ResultCard" Style="{StaticResource CardBorder}" Padding="16" Visibility="Collapsed">
                <TextBlock x:Name="ResultText" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
            </Border>

            <Button x:Name="NextButton" Style="{StaticResource PrimaryButton}" Click="Next_Click"
                    Content="Next puzzle" HorizontalAlignment="Stretch" />
            <Button x:Name="RetryButton" Style="{StaticResource TileButton}" Click="Retry_Click"
                    Content="Retry" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Visibility="Collapsed" />

            <ProgressRing x:Name="Busy" IsActive="False" Width="36" Height="36"
                          Foreground="{StaticResource AccentGreenLightBrush}" HorizontalAlignment="Left" />
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
