<Page
    x:Class="LichessXbox.Views.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}">

        <!-- Signed out -->
        <StackPanel x:Name="SignInPrompt" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="18" MaxWidth="520">
            <TextBlock Text="Sign in to see your games" FontSize="{StaticResource TitleSize}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
            <TextBlock Text="Your game history, ratings, and friends live on your Lichess account."
                       FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
            <Button x:Name="GoSignInButton" Style="{StaticResource PrimaryButton}" Click="GoSignIn_Click" HorizontalAlignment="Center" Content="Sign in with Lichess" />
        </StackPanel>

        <!-- The board grid scrolls itself (it must NOT be nested in a ScrollViewer, or its
             ItemsWrapGrid is measured with infinite height and realises every board at once). -->
        <Grid x:Name="GamesContent" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Games (grid of board thumbnails) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Your games" FontSize="{StaticResource TitleSize}" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14" />
                <StackPanel Grid.Row="1" Spacing="12" Margin="0,0,0,10">
                    <TextBlock x:Name="NoGames" Text="No games yet." FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" />
                    <Button x:Name="RetryGamesButton" Style="{StaticResource TileButton}" Click="Retry_Click"
                            Content="Refresh" HorizontalAlignment="Left" HorizontalContentAlignment="Center" MinWidth="160" Visibility="Collapsed" />
                    <ProgressRing x:Name="Busy" IsActive="False" Visibility="Collapsed" Width="34" Height="34" HorizontalAlignment="Left"
                                  Foreground="{StaticResource AccentGreenLightBrush}" />
                </StackPanel>
                <GridView Grid.Row="2" x:Name="GamesList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Game_ItemClick"
                          Padding="0,0,0,16" ScrollViewer.HorizontalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Padding="10" Width="184"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <Border CornerRadius="8" Width="164" Height="164">
                                        <controls:ChessBoardControl Fen="{Binding FinalFen}" WhiteAtBottom="{Binding PlayerWhite}"
                                                                    Interactive="False" IsTabStop="False" />
                                    </Border>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Headline}" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding OpponentRating}" FontSize="{StaticResource CaptionSize}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="{Binding TimeControlText}" FontSize="{StaticResource CaptionSize}"
                                               Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ResultText}" FontSize="{StaticResource CaptionSize}"
                                               Foreground="{Binding Outcome, Converter={StaticResource OutcomeBrush}}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Grid>
    </Grid>
</Page>
