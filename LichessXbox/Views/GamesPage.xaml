<Page
    x:Class="LichessXbox.Views.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="40,28">

        <!-- Signed out -->
        <StackPanel x:Name="SignInPrompt" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="18" MaxWidth="520">
            <TextBlock Text="Sign in to see your games" FontSize="36" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
            <TextBlock Text="Your game history, ratings, and friends live on your Lichess account."
                       FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
            <Button x:Name="GoSignInButton" Style="{StaticResource PrimaryButton}" Click="GoSignIn_Click" HorizontalAlignment="Center" Content="Sign in with Lichess" />
        </StackPanel>

        <ScrollViewer x:Name="GamesContent" IsTabStop="True" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" Visibility="Collapsed">
            <Grid Padding="0,0,12,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <!-- Games -->
                <StackPanel Grid.Column="0" Spacing="14" Margin="0,0,20,0">
                    <TextBlock Text="Your games" FontSize="{StaticResource TitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="NoGames" Text="No games yet." FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" />
                    <Button x:Name="RetryGamesButton" Style="{StaticResource TileButton}" Click="Retry_Click"
                            Content="Refresh" HorizontalAlignment="Left" HorizontalContentAlignment="Center" MinWidth="160" Visibility="Collapsed" />
                    <ProgressRing x:Name="Busy" IsActive="False" Width="34" Height="34" HorizontalAlignment="Left"
                                  Foreground="{StaticResource AccentGreenLightBrush}" />
                    <ListView x:Name="GamesList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Game_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="6,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Headline}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ResultText}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="▶ Replay" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource AccentGreenLightBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Rating + friends -->
                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="RatingTitle" Text="Blitz rating" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenLightBrush}" />
                            <Border Height="170" CornerRadius="10" Background="#16130F">
                                <Canvas x:Name="GraphCanvas" />
                            </Border>
                            <TextBlock x:Name="RatingRange" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Following" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                            <TextBlock x:Name="NoFollowing" Text="Not following anyone yet." FontSize="{StaticResource CaptionSize}"
                                       Foreground="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" />
                            <ItemsControl x:Name="FollowingList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
