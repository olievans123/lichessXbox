<Page
    x:Class="LichessXbox.Views.PlayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Page.Resources>
        <!-- Game-over card: a satisfying scale-overshoot pop-in. -->
        <Storyboard x:Key="ResultIn">
            <DoubleAnimation Storyboard.TargetName="ResultOverlay" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ResultCardScale" Storyboard.TargetProperty="ScaleX" From="0.84" To="1" Duration="0:0:0.36">
                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ResultCardScale" Storyboard.TargetProperty="ScaleY" From="0.84" To="1" Duration="0:0:0.36">
                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Padding="{StaticResource PagePadding}">

        <!-- ============ SIGN-IN REQUIRED ============ -->
        <StackPanel x:Name="SignInPrompt" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" MaxWidth="540">
            <TextBlock Text="Sign in to play" FontSize="{StaticResource TitleSize}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="You need a free Lichess account to play online games."
                       FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap" />
            <Button x:Name="GoSignInButton" Style="{StaticResource PrimaryButton}" Click="GoSignIn_Click"
                    HorizontalAlignment="Center" Content="Sign in with Lichess" />
        </StackPanel>

        <!-- ============ LOBBY — master-detail "Pairing Board" ============ -->
        <Grid x:Name="LobbyPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="New game" FontSize="{StaticResource TitleSize}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

            <Grid Grid.Row="1" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="216" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ===== MODE RAIL (active lane marked by a green left bar — distinct from the focus ring) ===== -->
                <StackPanel Grid.Column="0" Spacing="12">
                    <Button x:Name="OnlineModeButton" Style="{StaticResource TileButton}" Tag="online" Click="Mode_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="14,14">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="OnlineModeAccent" Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0"
                                    Background="{StaticResource AccentGreenLightBrush}" Visibility="Collapsed" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="🌐" FontSize="24" />
                                <TextBlock Text="Play online" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Human · ranked" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="ComputerModeButton" Style="{StaticResource TileButton}" Tag="computer" Click="Mode_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="14,14">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="ComputerModeAccent" Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0"
                                    Background="{StaticResource AccentGreenLightBrush}" Visibility="Collapsed" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="🤖" FontSize="24" />
                                <TextBlock Text="vs Computer" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Stockfish" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="FriendModeButton" Style="{StaticResource TileButton}" Tag="friend" Click="Mode_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="14,14">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="FriendModeAccent" Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0"
                                    Background="{StaticResource AccentGreenLightBrush}" Visibility="Collapsed" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="⚔️" FontSize="24" />
                                <TextBlock Text="Challenge" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="By username" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- ===== DETAIL ===== -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Incoming-challenge banner (amber; collapsed → no focus stops when empty) -->
                    <Border x:Name="ChallengeBanner" Grid.Row="0" Visibility="Collapsed" Margin="0,0,0,14"
                            CornerRadius="16" Padding="16,12" Background="{StaticResource WarningSurfaceBrush}" BorderBrush="{StaticResource WarningSurfaceStrongBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Incoming challenge" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <ScrollViewer MaxHeight="132" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                                <ItemsControl x:Name="ChallengesList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,6" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ChallengerName}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding Description}" FontSize="{StaticResource CaptionSize}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource PrimaryButton}" Content="Accept"
                                                            Tag="{Binding Id}" Click="AcceptChallenge_Click" MinWidth="120" />
                                                    <Button Style="{StaticResource TileButton}" Content="Decline" HorizontalContentAlignment="Center"
                                                            Tag="{Binding Id}" Click="DeclineChallenge_Click" MinWidth="120" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Content (one panel visible at a time) -->
                    <Grid Grid.Row="1">
                        <!-- (a) Play online — GridView owns a * row so its own scroll engages if needed -->
                        <Grid x:Name="PlayOnlinePanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Find a human opponent online" Margin="0,0,0,10" FontSize="{StaticResource BodySize}"
                                       FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                            <GridView Grid.Row="1" x:Name="PresetGrid" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Preset_ItemClick"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollMode="Disabled">
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="180" Height="92" CornerRadius="14"
                                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                            <StackPanel Margin="14,8" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding Glyph}" FontSize="22" />
                                                <TextBlock Text="{Binding Label}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding RatedLabel}" FontSize="{StaticResource CaptionSize}"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </Grid>

                        <!-- (b) vs Computer -->
                        <Grid x:Name="ComputerPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Choose a Stockfish level" Margin="0,0,0,10" FontSize="{StaticResource BodySize}"
                                       FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                            <GridView Grid.Row="1" x:Name="LevelGrid" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Ai_ItemClick"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollMode="Disabled">
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="108" Height="96" CornerRadius="16"
                                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="🤖" FontSize="22" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding Label}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                            <TextBlock Grid.Row="2" Text="1 = easiest · 8 = strongest" Margin="0,10,0,0" FontSize="{StaticResource CaptionSize}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>

                        <!-- (c) Challenge a friend -->
                        <StackPanel x:Name="FriendPanel" Spacing="14" Visibility="Collapsed">
                            <TextBlock Text="Challenge a Lichess player" FontSize="{StaticResource BodySize}"
                                       FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                            <TextBox x:Name="FriendBox" PlaceholderText="Lichess username" Width="420" Height="56" HorizontalAlignment="Left"
                                     FontSize="{StaticResource BodySize}" VerticalContentAlignment="Center"
                                     FocusVisualPrimaryBrush="{StaticResource AccentGreenLightBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                <Button x:Name="ChallengeButton" Style="{StaticResource PrimaryButton}" Click="Challenge_Click"
                                        Content="Send challenge" MinWidth="200" />
                                <TextBlock Text="Blitz 5+3 · casual" FontSize="{StaticResource CaptionSize}"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="ChallengeErrorText" Visibility="Collapsed" TextWrapping="Wrap"
                                       FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource ErrorBrush}" />
                        </StackPanel>
                    </Grid>

                    <!-- Footer: variant selector (opens the existing VariantGrid in a flyout) -->
                    <Grid Grid.Row="2" Margin="0,14,0,0" Padding="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.ColumnSpan="2" VerticalAlignment="Top" Height="1" Margin="0,-14,0,0"
                                Background="{StaticResource HairlineBrush}" />
                        <Button x:Name="VariantButton" Grid.Column="0" Style="{StaticResource TileButton}" Padding="16,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Variant:" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Normal" VerticalAlignment="Center" />
                                <TextBlock x:Name="VariantValueText" Text="Standard" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout x:Name="VariantFlyout" Placement="Top">
                                    <Flyout.FlyoutPresenterStyle>
                                        <Style TargetType="FlyoutPresenter">
                                            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                                            <Setter Property="CornerRadius" Value="16" />
                                            <Setter Property="Padding" Value="16" />
                                            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                                        </Style>
                                    </Flyout.FlyoutPresenterStyle>
                                    <GridView x:Name="VariantGrid" SelectionMode="Single" IsItemClickEnabled="True"
                                              ItemClick="Variant_ItemClick" MaxWidth="448" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <GridView.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="132" Height="88" CornerRadius="16"
                                                        Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock Text="{Binding Glyph}" FontSize="20" HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding Name}" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold" TextAlignment="Center"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <TextBlock x:Name="VariantNote" Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center"
                                   FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="Collapsed" TextWrapping="Wrap"
                                   Text="Variant games use server-validated moves; some inputs (Crazyhouse drops, Chess960 castling) aren't fully supported on the board yet." />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ============ SEEKING ============ -->
        <StackPanel x:Name="SeekingPanel" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
            <ProgressRing IsActive="True" Width="72" Height="72" Foreground="{StaticResource AccentGreenLightBrush}" />
            <TextBlock x:Name="SeekingText" Text="Finding an opponent…" FontSize="{StaticResource SubtitleSize}"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
            <Button x:Name="CancelSeekButton" Style="{StaticResource TileButton}" Click="CancelSeek_Click"
                    HorizontalAlignment="Center" Content="Cancel" MinWidth="200" HorizontalContentAlignment="Center" />
        </StackPanel>

        <!-- ============ GAME ============ -->
        <Grid x:Name="GamePanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="0" Stretch="Uniform">
                <controls:ChessBoardControl x:Name="Board" Interactive="True" />
            </Viewbox>

            <!-- Game-over result, revealed over the (dimmed) board -->
            <Grid x:Name="ResultOverlay" Grid.Column="0" Visibility="Collapsed">
                <Rectangle Fill="{StaticResource ScrimBrush}" />
                <Border MaxWidth="340" VerticalAlignment="Center" HorizontalAlignment="Center"
                        CornerRadius="{StaticResource RadiusLg}" Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ResultCardScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <StackPanel>
                        <Border x:Name="ResultAccent" Height="6" CornerRadius="20,20,0,0" Background="{StaticResource AccentGreenBrush}" />
                        <StackPanel Padding="28,24,28,22" Spacing="6">
                            <TextBlock x:Name="ResultIcon" FontFamily="Segoe MDL2 Assets" FontSize="40" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentGreenLightBrush}" Visibility="Collapsed" />
                            <TextBlock x:Name="ResultTitle" Text="" FontSize="{StaticResource TitleSize}" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="ResultMethod" Text="" FontSize="{StaticResource BodySize}"
                                       HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <StackPanel x:Name="ResultRatingRow" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"
                                        Visibility="Collapsed" Margin="0,2,0,0">
                                <TextBlock x:Name="ResultRating" FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock x:Name="ResultRatingDelta" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Visibility="Collapsed" />
                            </StackPanel>
                            <StackPanel Spacing="8" Margin="0,18,0,0">
                                <Button x:Name="ResultRematchButton" Style="{StaticResource PrimaryButton}" Padding="16,11" Click="Rematch_Click"
                                        Content="Rematch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="ResultNewGameButton" Style="{StaticResource TileButton}" Padding="16,11" Click="NewGame_Click"
                                        Content="New game" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                <Button x:Name="ResultReviewButton" Style="{StaticResource TileButton}" Padding="16,11" Click="ReviewGame_Click"
                                        Content="Review game" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                <Button x:Name="ResultViewBoardButton" Style="{StaticResource MoveButton}" Padding="8,6" Margin="0,6,0,0"
                                        FontSize="{StaticResource CaptionSize}" Click="DismissResult_Click"
                                        Content="View board" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Margin="20,0,0,0" Spacing="8">
                <!-- Opponent (top) -->
                <Border Style="{StaticResource CardBorder}" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TopName" Text="Opponent" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="TopRating" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                <TextBlock x:Name="TopCaptured" FontFamily="Segoe UI Symbol" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" MaxWidth="170" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="TopAdvantage" FontSize="{StaticResource CaptionSize}" FontWeight="Bold" Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <Border x:Name="TopClockChip" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource ClockChipBrush}" CornerRadius="10" Padding="14,7">
                            <TextBlock x:Name="TopClock" Text="--:--" FontSize="{StaticResource SubtitleSize}" FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="StatusBanner" Text="Your move" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenLightBrush}" TextWrapping="Wrap" />
                        <!-- Move history in algebraic notation (SAN); bounded, scrollable, current move highlighted. -->
                        <ScrollViewer x:Name="MoveScroller" MaxHeight="84" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                            <ItemsControl x:Name="MoveRows">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,1" ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding No}" FontSize="{StaticResource CaptionSize}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <!-- Each move is clickable to jump the board to that position. -->
                                            <Button Grid.Column="1" Style="{StaticResource MoveButton}" Tag="{Binding WhitePly}" Click="Move_Click"
                                                    Content="{Binding White}" Foreground="{Binding WhiteCurrent, Converter={StaticResource CurrentMoveBrush}}" />
                                            <Button Grid.Column="2" Style="{StaticResource MoveButton}" Tag="{Binding BlackPly}" Click="Move_Click"
                                                    Content="{Binding Black}" Foreground="{Binding BlackCurrent, Converter={StaticResource CurrentMoveBrush}}"
                                                    Visibility="{Binding BlackVisible}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <!-- Step through the game: first / previous / next / latest. -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="MoveFirstButton" Style="{StaticResource TileButton}" Padding="0,8" Click="MoveFirst_Click"
                                    FontFamily="Segoe MDL2 Assets" Content="&#xE892;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            <Button Grid.Column="1" x:Name="MovePrevButton" Style="{StaticResource TileButton}" Padding="0,8" Click="MovePrev_Click"
                                    FontFamily="Segoe MDL2 Assets" Content="&#xE76B;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            <Button Grid.Column="2" x:Name="MoveNextButton" Style="{StaticResource TileButton}" Padding="0,8" Click="MoveNext_Click"
                                    FontFamily="Segoe MDL2 Assets" Content="&#xE76C;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            <Button Grid.Column="3" x:Name="MoveLastButton" Style="{StaticResource TileButton}" Padding="0,8" Click="MoveLast_Click"
                                    FontFamily="Segoe MDL2 Assets" Content="&#xE893;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        </Grid>
                        <TextBlock x:Name="MovePositionText" Text="" FontSize="{StaticResource CaptionSize}"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- You (bottom) -->
                <Border Style="{StaticResource CardBorder}" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="BottomName" Text="You" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="BottomRating" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                <TextBlock x:Name="BottomCaptured" FontFamily="Segoe UI Symbol" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" MaxWidth="170" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="BottomAdvantage" FontSize="{StaticResource CaptionSize}" FontWeight="Bold" Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <Border x:Name="BottomClockChip" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource ClockChipBrush}" CornerRadius="10" Padding="14,7">
                            <TextBlock x:Name="BottomClock" Text="--:--" FontSize="{StaticResource SubtitleSize}" FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Incoming draw offer -->
                <Border x:Name="DrawOfferBanner" Visibility="Collapsed" CornerRadius="16" Padding="16,12"
                        Background="{StaticResource WarningSurfaceBrush}" BorderBrush="{StaticResource WarningSurfaceStrongBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Opponent offers a draw" FontSize="{StaticResource BodySize}" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Padding="16,10" Content="Accept"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="AcceptDraw_Click" />
                            <Button Grid.Column="1" Style="{StaticResource TileButton}" Padding="16,10" Content="Decline"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="DeclineDraw_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Spacing="6" Margin="0,2,0,0">
                    <Button x:Name="ResignButton" Style="{StaticResource TileButton}" Padding="16,10" Click="Resign_Click"
                            Content="Resign" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                    <Button x:Name="DrawButton" Style="{StaticResource TileButton}" Padding="16,10" Click="OfferDraw_Click"
                            Content="Offer draw" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                    <Button x:Name="TakebackButton" Style="{StaticResource TileButton}" Padding="16,10" Click="Takeback_Click"
                            Content="Takeback" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Spacing="6">
                    <Button x:Name="RematchButton" Style="{StaticResource PrimaryButton}" Padding="16,10" Click="Rematch_Click"
                            Content="Rematch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Visibility="Collapsed" />
                    <Button x:Name="NewGameButton" Style="{StaticResource TileButton}" Padding="16,10" Click="NewGame_Click"
                            Content="New game" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Visibility="Collapsed" />
                </StackPanel>
            </StackPanel>
