<Page
    x:Class="LichessXbox.Views.PlayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="40,28">

        <!-- ============ SIGN-IN REQUIRED ============ -->
        <StackPanel x:Name="SignInPrompt" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" MaxWidth="540">
            <TextBlock Text="Sign in to play" FontSize="{StaticResource TitleSize}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="You need a free Lichess account to play online games."
                       FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap" />
            <Button x:Name="GoSignInButton" Style="{StaticResource PrimaryButton}" Click="GoSignIn_Click"
                    HorizontalAlignment="Center" Content="Sign in with Lichess" />
        </StackPanel>

        <!-- ============ LOBBY ============ -->
        <ScrollViewer x:Name="LobbyPanel" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="22" Padding="0,0,12,24">
                <TextBlock Text="New game" FontSize="{StaticResource TitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />

                <!-- Quick pairing -->
                <TextBlock Text="Quick pairing" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                <TextBlock Text="Find a human opponent online (this searches until someone is matched)." FontSize="{StaticResource BodySize}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <GridView x:Name="PresetGrid" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Preset_ItemClick">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="240" Height="140" CornerRadius="16"
                                    Background="{StaticResource AppSurfaceHighBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <StackPanel Margin="20" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock Text="{Binding Glyph}" FontSize="36" />
                                    <TextBlock Text="{Binding Label}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding RatedLabel}" FontSize="{StaticResource CaptionSize}"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- Play the computer -->
                <TextBlock Text="Play the computer" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentGreenLightBrush}" Margin="0,8,0,0" />
                <TextBlock Text="Choose a Stockfish difficulty (1 = easiest, 8 = strongest)." FontSize="{StaticResource BodySize}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <GridView x:Name="LevelGrid" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Ai_ItemClick">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="110" Height="100" CornerRadius="16"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🤖" FontSize="26" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- Challenge a player -->
                <TextBlock Text="Challenge a player" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentGreenLightBrush}" Margin="0,8,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBox x:Name="FriendBox" PlaceholderText="Lichess username" Width="300" Height="56"
                             FontSize="{StaticResource BodySize}" VerticalContentAlignment="Center"
                             FocusVisualPrimaryBrush="{StaticResource AccentGreenLightBrush}" />
                    <Button x:Name="ChallengeButton" Style="{StaticResource PrimaryButton}" Click="Challenge_Click"
                            Content="Challenge" MinWidth="180" />
                </StackPanel>
                <TextBlock x:Name="ChallengeErrorText" Visibility="Collapsed" TextWrapping="Wrap"
                           FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource ErrorBrush}" />

                <!-- Variant (Standard by default; choose before pairing) -->
                <TextBlock Text="Variant" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" Margin="0,8,0,0" />
                <GridView x:Name="VariantGrid" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="Variant_ItemClick">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="132" Height="88" CornerRadius="16"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding Glyph}" FontSize="20" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold" TextAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
                <TextBlock x:Name="VariantNote" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}"
                           Visibility="Collapsed" TextWrapping="Wrap"
                           Text="Variant games are played with server-validated moves; some inputs (Crazyhouse drops, Chess960 castling) aren't fully supported on the board yet." />

                <!-- Incoming challenges -->
                <TextBlock Text="Challenges" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentGreenLightBrush}" Margin="0,8,0,0" />
                <TextBlock x:Name="NoChallengesText" Text="No incoming challenges." FontSize="{StaticResource BodySize}"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <ItemsControl x:Name="ChallengesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="16" Margin="0,0,0,10" Padding="20,14"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ChallengerName}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Description}" FontSize="{StaticResource CaptionSize}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryButton}" Content="Accept"
                                                Tag="{Binding Id}" Click="AcceptChallenge_Click" MinWidth="120" />
                                        <Button Style="{StaticResource TileButton}" Content="Decline" HorizontalContentAlignment="Center"
                                                Tag="{Binding Id}" Click="DeclineChallenge_Click" MinWidth="120" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- ============ SEEKING ============ -->
        <StackPanel x:Name="SeekingPanel" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
            <ProgressRing IsActive="True" Width="72" Height="72" Foreground="{StaticResource AccentGreenLightBrush}" />
            <TextBlock x:Name="SeekingText" Text="Finding an opponent…" FontSize="{StaticResource SubtitleSize}"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
            <Button x:Name="CancelSeekButton" Style="{StaticResource TileButton}" Click="CancelSeek_Click"
                    HorizontalAlignment="Center" Content="Cancel" MinWidth="200" HorizontalContentAlignment="Center" />
        </StackPanel>

        <!-- ============ GAME ============ -->
        <Grid x:Name="GamePanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="0" Stretch="Uniform">
                <controls:ChessBoardControl x:Name="Board" Interactive="True" />
            </Viewbox>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Margin="20,0,0,0" Spacing="16">
                <!-- Opponent (top) -->
                <Border Style="{StaticResource CardBorder}" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TopName" Text="Opponent" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="TopRating" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                <TextBlock x:Name="TopCaptured" FontFamily="Segoe UI Symbol" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" MaxWidth="170" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="TopAdvantage" FontSize="{StaticResource CaptionSize}" FontWeight="Bold" Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource ClockChipBrush}" CornerRadius="10" Padding="16,8">
                            <TextBlock x:Name="TopClock" Text="--:--" FontSize="{StaticResource SubtitleSize}" FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="20">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="StatusBanner" Text="Your move" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenLightBrush}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180" HorizontalScrollMode="Disabled">
                            <TextBlock x:Name="MoveList" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- You (bottom) -->
                <Border Style="{StaticResource CardBorder}" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="BottomName" Text="You" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="BottomRating" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                <TextBlock x:Name="BottomCaptured" FontFamily="Segoe UI Symbol" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" MaxWidth="170" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="BottomAdvantage" FontSize="{StaticResource CaptionSize}" FontWeight="Bold" Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource ClockChipBrush}" CornerRadius="10" Padding="16,8">
                            <TextBlock x:Name="BottomClock" Text="--:--" FontSize="{StaticResource SubtitleSize}" FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Incoming draw offer -->
                <Border x:Name="DrawOfferBanner" Visibility="Collapsed" CornerRadius="16" Padding="16,12"
                        Background="#33F2D26B" BorderBrush="#88F2D26B" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Opponent offers a draw" FontSize="{StaticResource BodySize}" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Content="Accept"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="AcceptDraw_Click" />
                            <Button Grid.Column="1" Style="{StaticResource TileButton}" Content="Decline"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="DeclineDraw_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Spacing="8" Margin="0,4,0,0">
                    <Button x:Name="ResignButton" Style="{StaticResource TileButton}" Click="Resign_Click"
                            Content="Resign" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                    <Button x:Name="DrawButton" Style="{StaticResource TileButton}" Click="OfferDraw_Click"
                            Content="Offer draw" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                    <Button x:Name="TakebackButton" Style="{StaticResource TileButton}" Click="Takeback_Click"
                            Content="Takeback" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Spacing="8">
                    <Button x:Name="RematchButton" Style="{StaticResource PrimaryButton}" Click="Rematch_Click"
                            Content="Rematch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Visibility="Collapsed" />
                    <Button x:Name="NewGameButton" Style="{StaticResource TileButton}" Click="NewGame_Click"
                            Content="New game" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Visibility="Collapsed" />
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
