<Page
    x:Class="LichessXbox.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="32,24,32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left: hero + actions. Placed directly in the grid column (which has a
             definite width) rather than inside a ScrollViewer — a ScrollViewer hands
             its content infinite width on the first measure pass, which let the
             stretch-buttons blow past MaxWidth on first launch. -->
        <StackPanel Grid.Column="0" Spacing="18" VerticalAlignment="Center" Margin="0,0,20,0">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="GreetingText" Text="Welcome" FontSize="16"
                               Foreground="{StaticResource AccentGreenLightBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Play the world." FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="Free chess on your TV. No ads, no nonsense — powered by lichess.org."
                               FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Left">
                    <Button x:Name="PlayButton" Style="{StaticResource TileButton}" Click="Play_Click" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <TextBlock Text="♟" FontFamily="Segoe UI Symbol" FontSize="32" Foreground="{StaticResource AccentGreenLightBrush}" />
                            <StackPanel>
                                <TextBlock Text="Play online" FontSize="21" FontWeight="SemiBold" />
                                <TextBlock Text="Bullet · Blitz · Rapid · Classical" FontSize="{StaticResource CaptionSize}"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TileButton}" Click="Tv_Click" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <TextBlock Text="📺" FontSize="28" />
                            <StackPanel>
                                <TextBlock Text="Watch TV" FontSize="21" FontWeight="SemiBold" />
                                <TextBlock Text="The best live game, right now" FontSize="{StaticResource CaptionSize}"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TileButton}" Click="Puzzles_Click" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <TextBlock Text="🧩" FontSize="28" />
                            <StackPanel>
                                <TextBlock Text="Solve puzzles" FontSize="21" FontWeight="SemiBold" />
                                <TextBlock Text="Sharpen your tactics" FontSize="{StaticResource CaptionSize}"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

        <!-- Right: decorative board preview (fixed size so it can't squeeze the content) -->
        <Border Grid.Column="1" Width="248" Height="248" VerticalAlignment="Center"
                CornerRadius="16" Padding="12" Background="#22000000" BorderBrush="#22FFFFFF" BorderThickness="1">
            <controls:ChessBoardControl x:Name="PreviewBoard" Interactive="False" />
        </Border>
    </Grid>
</Page>
