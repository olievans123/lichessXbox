<Page
    x:Class="LichessXbox.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="40,32,40,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Left: hero + actions -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="28" Margin="0,0,40,0">
            <StackPanel Spacing="6">
                <TextBlock x:Name="GreetingText" Text="Welcome" FontSize="20"
                           Foreground="{StaticResource AccentGreenLightBrush}" FontWeight="SemiBold" />
                <TextBlock Text="Play the world." FontSize="64" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" LineHeight="68" />
                <TextBlock Text="Free chess on your TV. No ads, no nonsense — powered by lichess.org."
                           FontSize="20" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Spacing="14" MaxWidth="560">
                <Button x:Name="PlayButton" Style="{StaticResource TileButton}" Click="Play_Click">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <TextBlock Text="♟" FontFamily="Segoe UI Symbol" FontSize="34" Foreground="{StaticResource AccentGreenLightBrush}" />
                        <StackPanel>
                            <TextBlock Text="Play online" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="Bullet · Blitz · Rapid · Classical" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource TileButton}" Click="Tv_Click">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <TextBlock Text="📺" FontSize="30" />
                        <StackPanel>
                            <TextBlock Text="Watch TV" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="The best live game, right now" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource TileButton}" Click="Puzzles_Click">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <TextBlock Text="🧩" FontSize="30" />
                        <StackPanel>
                            <TextBlock Text="Solve puzzles" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="Sharpen your tactics" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Right: decorative live board preview -->
        <Grid Grid.Column="1">
            <Border CornerRadius="22" Padding="24" Background="#22000000" BorderBrush="#22FFFFFF" BorderThickness="1">
                <controls:ChessBoardControl x:Name="PreviewBoard" Interactive="False" />
            </Border>
        </Grid>
    </Grid>
</Page>
