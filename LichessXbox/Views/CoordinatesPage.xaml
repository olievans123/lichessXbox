<Page
    x:Class="LichessXbox.Views.CoordinatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0" Stretch="Uniform" MaxWidth="560" MaxHeight="560" HorizontalAlignment="Center">
            <Border CornerRadius="10" Background="#0E0C09" Padding="8">
                <Grid x:Name="CoordGrid" Width="704" Height="704" />
            </Border>
        </Viewbox>

        <!-- Scrollable + compact so the panel never clips on the ~540 DIP-tall TV canvas. -->
        <ScrollViewer Grid.Column="1" Margin="28,0,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="16" Padding="0,24,8,24" VerticalAlignment="Center">
                <TextBlock Text="Coordinate trainer" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Find the named square as fast as you can. 30 seconds." FontSize="{StaticResource CaptionSize}"
                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />

                <Border Style="{StaticResource CardBorder}" Padding="20,16" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="Find" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="TargetText" Text="—" FontSize="60" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenLightBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Score" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="ScoreText" Text="0" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="Time" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="TimeText" Text="30" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Grid>

                <Button x:Name="StartButton" Style="{StaticResource PrimaryButton}" Click="Start_Click"
                        Content="Start" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
