<Page
    x:Class="LichessXbox.Views.CoordinatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0" Stretch="Uniform">
            <Border CornerRadius="10" Background="#0E0C09" Padding="8">
                <Grid x:Name="CoordGrid" Width="704" Height="704" />
            </Border>
        </Viewbox>

        <StackPanel Grid.Column="1" Margin="28,0,0,0" Spacing="20" VerticalAlignment="Center">
            <TextBlock Text="Coordinate trainer" FontSize="{StaticResource TitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Find the named square as fast as you can. 30 seconds." FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />

            <Border Style="{StaticResource CardBorder}" Padding="24" HorizontalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="Find" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="TargetText" Text="—" FontSize="72" FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenLightBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Grid>
                <StackPanel>
                    <TextBlock Text="Score" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="ScoreText" Text="0" FontSize="34" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right">
                    <TextBlock Text="Time" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="TimeText" Text="30" FontSize="34" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
            </Grid>

            <Button x:Name="StartButton" Style="{StaticResource PrimaryButton}" Click="Start_Click"
                    Content="Start" MinWidth="200" HorizontalAlignment="Stretch" />
        </StackPanel>
    </Grid>
</Page>
