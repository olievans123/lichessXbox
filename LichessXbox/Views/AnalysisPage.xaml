<Page
    x:Class="LichessXbox.Views.AnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Eval bar -->
        <Border Grid.Column="0" Width="22" Margin="0,4,12,4" CornerRadius="11" Background="#161310">
            <Grid RenderTransformOrigin="0.5,0.5">
                <!-- Flipped (ScaleY = -1) together with the board so White's share stays on White's side. -->
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="EvalBarFlip" ScaleY="1" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="BlackShare" Height="1*" />
                    <RowDefinition x:Name="WhiteShare" Height="1*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#26221C" />
                <Border Grid.Row="1" Background="#EFEADF" />
            </Grid>
        </Border>

        <!-- Board -->
        <Viewbox Grid.Column="1" Stretch="Uniform">
            <controls:ChessBoardControl x:Name="Board" Interactive="True" />
        </Viewbox>

        <!-- Hidden host for the local Stockfish engine -->
        <WebView x:Name="EngineWeb" Grid.Column="0" Width="1" Height="1" Opacity="0"
                 IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top" />

        <!-- Side panel: a fixed, height-bounded grid. Every region keeps a stable size and scrolls
             INTERNALLY, so playing a move never reflows or jars the panel. The explorer fills the
             leftover height; Moves is a small fixed box that's always present. -->
        <Grid Grid.Column="2" Margin="20,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header + FEN loader (behind a button) -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Analysis" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="PlayersText" Visibility="Collapsed" FontSize="{StaticResource CaptionSize}"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <!-- Always present (fixed 1-line height) so the opening name appearing can't shift the panel. -->
                    <TextBlock x:Name="OpeningNameText" Height="20" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGreenLightBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="44" Height="44" CornerRadius="22"
                        VerticalAlignment="Top" Background="{StaticResource AppSurfaceHighBrush}"
                        FontFamily="Segoe MDL2 Assets" FontSize="18" Content="&#xE8E5;"
                        ToolTipService.ToolTip="Load position (FEN)">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Width="300" Spacing="10">
                                <TextBlock Text="Load position (FEN)" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBox x:Name="FenBox" FontSize="{StaticResource CaptionSize}" Height="52" VerticalContentAlignment="Center"
                                         PlaceholderText="Paste a FEN…" />
                                <Button Style="{StaticResource PrimaryButton}" Click="LoadFen_Click" Content="Load" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                <Button Style="{StaticResource TileButton}" Click="StartPos_Click" Content="Start position" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <!-- Engine eval — compact: eval + depth + source toggle on one row, then a 1-line PV.
                 Kept tight so the opening explorer below gets real, scrollable height. -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,8">
                <StackPanel Spacing="6">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="EvalText" Grid.Column="0" Text="—" FontSize="{StaticResource SubtitleSize}" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="DepthText" Grid.Column="1" Text="" FontSize="{StaticResource CaptionSize}"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <ToggleSwitch x:Name="LocalEngineToggle" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      MinWidth="0" OffContent="Cloud" OnContent="Local" Toggled="LocalEngine_Toggled" />
                    </Grid>
                    <!-- 1-line PV (ellipsis). Fixed height keeps the panel from reflowing as the engine deepens. -->
                    <TextBlock x:Name="BestLineText" Text="Evaluating…" FontSize="{StaticResource CaptionSize}"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="NoWrap"
                               Height="20" MaxLines="1" TextTrimming="CharacterEllipsis" VerticalAlignment="Top" />
                </StackPanel>
            </Border>

            <!-- Navigation -->
            <Grid Grid.Row="2" ColumnSpacing="6" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource TileButton}" Click="First_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE892;" Padding="0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Button Grid.Column="1" x:Name="BackButton" Style="{StaticResource TileButton}" Click="Back_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE76B;" Padding="0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Button Grid.Column="2" Style="{StaticResource TileButton}" Click="Forward_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE76C;" Padding="0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Button Grid.Column="3" Style="{StaticResource TileButton}" Click="Last_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE893;" Padding="0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Button Grid.Column="4" Style="{StaticResource TileButton}" Click="Flip_Click" FontFamily="Segoe MDL2 Assets" Content="&#xE8AB;" Padding="0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
            </Grid>

            <!-- Moves: clickable, jump the board to any position (like the Play board) -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="Moves" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                    <Grid Height="44">
                        <TextBlock x:Name="MovesEmpty" Text="No moves yet." FontSize="{StaticResource CaptionSize}"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Top" />
                        <ScrollViewer x:Name="AnalysisMoveScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                            <ItemsControl x:Name="AnalysisMoveRows">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,1" ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding No}" FontSize="{StaticResource CaptionSize}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <Button Grid.Column="1" Style="{StaticResource MoveButton}" Tag="{Binding WhitePly}" Click="Move_Click"
                                                Content="{Binding White}" Foreground="{Binding WhiteCurrent, Converter={StaticResource CurrentMoveBrush}}" />
                                        <Button Grid.Column="2" Style="{StaticResource MoveButton}" Tag="{Binding BlackPly}" Click="Move_Click"
                                                Content="{Binding Black}" Foreground="{Binding BlackCurrent, Converter={StaticResource CurrentMoveBrush}}"
                                                Visibility="{Binding BlackVisible}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Opening explorer: fills the remaining height; the list scrolls internally. -->
            <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,8">
                        <TextBlock x:Name="OpeningText" Text="Opening explorer" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenLightBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="ExplorerEmpty" Text="No opening data for this position." FontSize="{StaticResource CaptionSize}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" />
                    </StackPanel>
                    <ListView Grid.Row="1" x:Name="ExplorerList" SelectionMode="None" IsItemClickEnabled="True"
                              ItemClick="Explorer_ItemClick" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <!-- Soft, thin focus outline (not the heavy green reveal ring) for these clickable rows. -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="FocusVisualPrimaryBrush" Value="#59EFEADF" />
                                <Setter Property="FocusVisualSecondaryBrush" Value="Transparent" />
                                <Setter Property="FocusVisualPrimaryThickness" Value="1" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding San}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{Binding Stats}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <StackPanel Orientation="Horizontal" Height="14">
                                            <Border Width="{Binding BarWhite}" Background="#EFEADF" CornerRadius="3,0,0,3" />
                                            <Border Width="{Binding BarDraw}" Background="#8A8470" />
                                            <Border Width="{Binding BarBlack}" Background="#3A352B" CornerRadius="0,3,3,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Tablebase (appears in endgames, below the explorer) -->
            <Border x:Name="TablebaseCard" Grid.Row="5" Style="{StaticResource CardBorder}" Padding="16" Margin="0,12,0,0" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="TablebaseSummary" Text="Tablebase" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGreenLightBrush}" />
                    <ListView x:Name="TablebaseList" SelectionMode="None" IsItemClickEnabled="True"
                              ItemClick="Tablebase_ItemClick" MaxHeight="160" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="FocusVisualPrimaryBrush" Value="#59EFEADF" />
                                <Setter Property="FocusVisualSecondaryBrush" Value="Transparent" />
                                <Setter Property="FocusVisualPrimaryThickness" Value="1" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding San}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Outcome}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
