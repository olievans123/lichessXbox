<Page
    x:Class="LichessXbox.Views.StudiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="{StaticResource PagePadding}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
        <StackPanel Spacing="18" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Studies" FontSize="{StaticResource TitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Browse any Lichess member's public studies and open them on the analysis board."
                       FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}" />

            <StackPanel Orientation="Horizontal" Spacing="14">
                <TextBox x:Name="UserBox" PlaceholderText="Lichess username" Width="280" Height="52"
                         FontSize="{StaticResource BodySize}" VerticalContentAlignment="Center" />
                <Button x:Name="LoadButton" Style="{StaticResource PrimaryButton}" Click="Load_Click"
                        Content="Find studies" MinWidth="180" Height="52" Padding="24,0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- One slim status strip (ring + text inline) — collapses when idle, so there's no
                 phantom gap between the search row and the results. -->
            <StackPanel x:Name="StatusStrip" Orientation="Horizontal" Spacing="10" Visibility="Collapsed">
                <ProgressRing x:Name="Busy" IsActive="False" Visibility="Collapsed" Width="24" Height="24"
                              Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText" Text="" FontSize="{StaticResource CaptionSize}" TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <ListView x:Name="StudyList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Study_ItemClick" ScrollViewer.VerticalScrollMode="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="18,14"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="Open" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Chapter picker (shown when a multi-chapter study is opened) -->
            <StackPanel x:Name="ChaptersPanel" Visibility="Collapsed" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="ChaptersBackButton" Style="{StaticResource TileButton}" Click="ChaptersBack_Click"
                            Content="‹ Studies" Padding="16,8" />
                    <TextBlock x:Name="ChaptersTitle" Text="" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGreenLightBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <ListView x:Name="ChapterList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Chapter_ItemClick" ScrollViewer.VerticalScrollMode="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="18,14"
                                    Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding Name}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
