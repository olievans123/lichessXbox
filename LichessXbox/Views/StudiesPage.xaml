<Page
    x:Class="LichessXbox.Views.StudiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="40,28">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
        <StackPanel Spacing="18" MaxWidth="620" HorizontalAlignment="Left">
            <TextBlock Text="Studies" FontSize="{StaticResource TitleSize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Browse any Lichess member's public studies and open them on the analysis board."
                       FontSize="{StaticResource BodySize}" Foreground="{StaticResource TextSecondaryBrush}" />

            <StackPanel Orientation="Horizontal" Spacing="14">
                <TextBox x:Name="UserBox" PlaceholderText="Lichess username" Width="280" Height="56"
                         FontSize="{StaticResource BodySize}" VerticalContentAlignment="Center" />
                <Button x:Name="LoadButton" Style="{StaticResource PrimaryButton}" Click="Load_Click"
                        Content="Find studies" MinWidth="180" Height="56" VerticalAlignment="Center" />
            </StackPanel>

            <ProgressRing x:Name="Busy" IsActive="False" Width="36" Height="36" HorizontalAlignment="Left"
                          Foreground="{StaticResource AccentGreenLightBrush}" />
            <TextBlock x:Name="StatusText" Text="" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />

            <ListView x:Name="StudyList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Study_ItemClick" ScrollViewer.VerticalScrollMode="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="18,14"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Owner}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="Open ▶" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource AccentGreenLightBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
