<Page
    x:Class="LichessXbox.Views.StudiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="40,28">
        <StackPanel Spacing="18" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="Studies" FontSize="40" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Browse any Lichess member's public studies and open them on the analysis board."
                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />

            <StackPanel Orientation="Horizontal" Spacing="14">
                <TextBox x:Name="UserBox" PlaceholderText="Lichess username" Width="360" Height="56"
                         FontSize="18" VerticalContentAlignment="Center" />
                <Button x:Name="LoadButton" Style="{StaticResource PrimaryButton}" Click="Load_Click"
                        Content="Find studies" MinWidth="180" />
            </StackPanel>

            <ProgressRing x:Name="Busy" IsActive="False" Width="36" Height="36" HorizontalAlignment="Left"
                          Foreground="{StaticResource AccentGreenLightBrush}" />
            <TextBlock x:Name="StatusText" Text="" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" />

            <ListView x:Name="StudyList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Study_ItemClick" MaxHeight="640">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="18,14" Margin="0,0,0,10"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="#22FFFFFF" BorderThickness="1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Owner}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock Text="Open ▶" FontSize="14" Foreground="{StaticResource AccentGreenLightBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
