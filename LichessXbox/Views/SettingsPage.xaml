<Page
    x:Class="LichessXbox.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
        <StackPanel Padding="48,32" Spacing="22" MaxWidth="1000" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="40" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />

            <TextBlock Text="Board theme" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
            <GridView x:Name="ThemeGrid" SelectionMode="None" IsItemClickEnabled="True" ItemClick="Theme_ItemClick">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Height="120" CornerRadius="14" Margin="6"
                                Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <StackPanel Margin="14" Spacing="8">
                                <Grid Height="48" CornerRadius="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding LightBrush}" />
                                    <Border Grid.Column="1" Background="{Binding DarkBrush}" />
                                    <Border Grid.Column="2" Background="{Binding LightBrush}" />
                                    <Border Grid.Column="3" Background="{Binding DarkBrush}" />
                                </Grid>
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Border Style="{StaticResource CardBorder}" Padding="24">
                <StackPanel Spacing="18">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Outline piece set" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Use hollow glyphs for the white pieces." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="OutlineToggle" HorizontalAlignment="Right" Toggled="Outline_Toggled" />
                    </Grid>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="UI sounds" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Play navigation sounds when moving focus." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="SoundToggle" HorizontalAlignment="Right" Toggled="Sound_Toggled" />
                    </Grid>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Move sounds" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Play a sound for each move, capture, and check." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="MoveSoundToggle" HorizontalAlignment="Right" Toggled="MoveSound_Toggled" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="24">
                <StackPanel Spacing="6">
                    <TextBlock Text="More tools" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenLightBrush}" />
                    <TextBlock Text="Board editor and the coordinate trainer are in their own tabs." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button Style="{StaticResource TileButton}" Click="Editor_Click" Content="Board editor" HorizontalContentAlignment="Center" MinWidth="180" />
                        <Button Style="{StaticResource TileButton}" Click="Coords_Click" Content="Coordinate trainer" HorizontalContentAlignment="Center" MinWidth="220" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
