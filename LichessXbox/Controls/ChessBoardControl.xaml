<UserControl
    x:Class="LichessXbox.Controls.ChessBoardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    IsTabStop="True"
    UseSystemFocusVisuals="False"
    Background="Transparent">

    <Viewbox Stretch="Uniform">
        <Grid x:Name="BoardRoot" Width="720" Height="720">
            <Border CornerRadius="12" Background="{StaticResource BoardFrameBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" />
            <Grid x:Name="BoardGrid" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" />
                    <RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" /><RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
            </Grid>

            <!-- Best-move arrows: drawn over the pieces, below the sliding piece + picker. -->
            <Canvas x:Name="ArrowLayer" Margin="8" Width="704" Height="704" IsHitTestVisible="False" />

            <!-- Animation layer: a single piece slides across here, on top of the squares
                 but below the promotion picker. Never a hit-test / focus target. -->
            <Canvas x:Name="AnimLayer" Margin="8" IsHitTestVisible="False" />

            <!-- Promotion picker overlay -->
            <Border x:Name="PromotionOverlay" Visibility="Collapsed"
                    Background="#E6000000" CornerRadius="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <TextBlock Text="Promote to" FontSize="28" Foreground="White"
                               HorizontalAlignment="Center" FontWeight="SemiBold" />
                    <StackPanel x:Name="PromotionButtons" Orientation="Horizontal" Spacing="14" />
                </StackPanel>
            </Border>

            <!-- Whole-board focus state: shown when the board holds focus as a single unit
                 (before you press A to engage). A soft dark halo lifts it off the page and a
                 bright accent ring says "this is selected — press A to play the board". Once
                 engaged it hides and the per-square cream cursor takes over. -->
            <Grid x:Name="BoardGlow" Visibility="Collapsed" IsHitTestVisible="False">
                <Border CornerRadius="15" Margin="-4" BorderThickness="7">
                    <Border.BorderBrush><SolidColorBrush Color="#73000000" /></Border.BorderBrush>
                </Border>
                <Border CornerRadius="12" BorderThickness="4">
                    <Border.BorderBrush><SolidColorBrush Color="{StaticResource AccentGreenLightColor}" /></Border.BorderBrush>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</UserControl>
