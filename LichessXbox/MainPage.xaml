<Page
    x:Class="LichessXbox.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls">

    <Page.Resources>
        <!-- Slide + fade the "continue playing" cards in from the right when expanding. -->
        <Storyboard x:Key="OngoingPanelOpen">
            <DoubleAnimation Storyboard.TargetName="OngoingPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="OngoingPanelTransform" Storyboard.TargetProperty="X" From="44" To="0" Duration="0:0:0.24">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="OngoingPanelClose">
            <DoubleAnimation Storyboard.TargetName="OngoingPanel" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="OngoingPanelTransform" Storyboard.TargetProperty="X" From="0" To="44" Duration="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="OngoingTabIn">
            <DoubleAnimation Storyboard.TargetName="OngoingTab" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.16" />
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="HeroGradientBrush" />
        </Grid.Background>

        <!-- Collapsible navigation. The pane is hidden by default so the board/content
             gets the full width; the hamburger (and the gamepad Menu button) reveal it. -->
        <SplitView x:Name="NavSplit" DisplayMode="Overlay" OpenPaneLength="252"
                   IsPaneOpen="False" PaneBackground="{StaticResource AppSurfaceBrush}">
            <SplitView.Pane>
                <ScrollViewer x:Name="NavScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NavItems" Padding="12,16,12,16" Spacing="3">
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="6,2,6,6">
                            <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource AccentGradientBrush}">
                                <TextBlock Text="♞" FontFamily="Segoe UI Symbol" FontSize="26" Foreground="#0E1207"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="lichess" FontSize="{StaticResource BodySize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="for Xbox" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button x:Name="HomeNav" Style="{StaticResource NavButton}" Tag="home" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🏠" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Home" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="play" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="♟️" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Play" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="watch" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📺" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Watch" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="analysis" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔬" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Analysis" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="puzzles" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🧩" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Puzzles" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="tournaments" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🏆" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Tournaments" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="studies" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📚" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Studies" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="games" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📋" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Games" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="profile" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="👤" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Profile" Margin="8,0,0,0" />
                            </Grid>
                        </Button>

                        <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="8,8,8,8" />

                        <Button Style="{StaticResource NavButton}" Tag="editor" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✏️" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Board editor" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="coords" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🎯" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Coordinates" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="settings" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⚙️" FontFamily="Segoe UI Emoji" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Settings" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </SplitView.Pane>

            <!-- Content: a slim gutter holds the hamburger so it never overlaps a page title. -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="MenuButton" Grid.Column="0" Click="ToggleNav_Click"
                        Style="{StaticResource IconButton}"
                        VerticalAlignment="Top" HorizontalAlignment="Center"
                        Width="44" Height="44" Margin="0,12,0,0" CornerRadius="22"
                        Background="#59000000"
                        FontFamily="Segoe MDL2 Assets" FontSize="18"
                        Content="&#xE700;" ToolTipService.ToolTip="Menu (Menu button)" />

                <Frame x:Name="ContentFrame" Grid.Column="1" />

                <!-- "Continue playing": collapsed to a small tab on the right edge by default so it
                     isn't always over the content; selecting it expands the in-progress game cards. -->
                <Button x:Name="OngoingTab" Grid.Column="1" Visibility="Collapsed" Style="{StaticResource TileButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,16"
                        Background="{StaticResource AppSurfaceBrush}" Padding="14,10" HorizontalContentAlignment="Center"
                        Click="ExpandOngoing_Click" ToolTipService.ToolTip="Games in progress">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="◂" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Ellipse x:Name="OngoingTabDot" Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="{StaticResource AccentGreenLightBrush}" Visibility="Collapsed" />
                        <TextBlock Text="♟" FontFamily="Segoe UI Symbol" FontSize="18" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentGreenLightBrush}" />
                        <TextBlock x:Name="OngoingTabCount" Text="0" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Button>

                <Border x:Name="OngoingPanel" Grid.Column="1" Visibility="Collapsed"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,16" MaxWidth="320"
                        CornerRadius="18" Padding="14,12" Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" RenderTransformOrigin="1,1">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="OngoingPanelTransform" />
                    </Border.RenderTransform>
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Continue playing" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Foreground="{StaticResource AccentGreenLightBrush}" />
                            <Button Grid.Column="1" x:Name="OngoingCollapseButton" Style="{StaticResource IconButton}"
                                    Width="32" Height="32" CornerRadius="16" Background="{StaticResource AppSurfaceHighBrush}"
                                    FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Content="▸"
                                    Click="CollapseOngoing_Click" ToolTipService.ToolTip="Collapse" />
                        </Grid>
                        <ItemsControl x:Name="OngoingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource TileButton}" Padding="10" Margin="0,0,0,8"
                                            HorizontalContentAlignment="Left" Tag="{Binding GameId}" Click="OngoingGame_Click">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="76" Height="76" CornerRadius="8">
                                                <controls:ChessBoardControl Fen="{Binding Fen}" WhiteAtBottom="{Binding WhiteAtBottom}"
                                                                            Interactive="False" IsTabStop="False" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="{StaticResource AccentGreenLightBrush}"
                                                             Opacity="{Binding IsMyTurn, Converter={StaticResource BoolToOpacity}}" />
                                                    <TextBlock Text="{Binding OpponentName}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Status}" FontSize="{StaticResource CaptionSize}" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </SplitView>
    </Grid>
</Page>
