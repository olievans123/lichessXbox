<Page
    x:Class="LichessXbox.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LichessXbox.Controls">

    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="HeroGradientBrush" />
        </Grid.Background>

        <!-- Collapsible navigation. The pane is hidden by default so the board/content
             gets the full width; the hamburger (and the gamepad Menu button) reveal it. -->
        <SplitView x:Name="NavSplit" DisplayMode="Overlay" OpenPaneLength="252"
                   IsPaneOpen="False" PaneBackground="{StaticResource AppSurfaceBrush}">
            <SplitView.Pane>
                <ScrollViewer x:Name="NavScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NavItems" Padding="24,16,12,16" Spacing="3">
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="6,2,6,6">
                            <!-- The real app icon (knight artwork), not a glyph approximation. -->
                            <Border Width="40" Height="40" CornerRadius="10">
                                <Border.Background>
                                    <ImageBrush ImageSource="ms-appx:///Assets/Square150x150Logo.scale-200.png" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Online Chess" FontSize="{StaticResource BodySize}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="powered by lichess" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Style="{StaticResource NavButton}" Tag="home" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE80F;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Home" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="play" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE768;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Play" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="watch" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE93E;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Watch" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="analysis" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE721;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Analysis" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="puzzles" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xEA80;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Puzzles" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="tournaments" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE716;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Tournaments" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="studies" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE8F1;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Studies" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="games" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE8FD;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Games" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="profile" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE77B;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Profile" Margin="8,0,0,0" />
                            </Grid>
                        </Button>

                        <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="8,8,8,8" />

                        <Button Style="{StaticResource NavButton}" Tag="editor" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE70F;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Board editor" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="coords" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xF0E2;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Coordinates" Margin="8,0,0,0" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Tag="settings" Click="Nav_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE713;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Settings" Margin="8,0,0,0" />
                            </Grid>
                        </Button>

                        <!-- Controller crib sheet — quiet, at the end of the list. -->
                        <TextBlock Margin="10,16,6,4" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" LineHeight="20"
                                   Text="☰ Menu — this panel&#10;Ⓑ — back / close&#10;⧉ View — your games" />
                    </StackPanel>
                </ScrollViewer>
            </SplitView.Pane>

            <!-- Content: a slim gutter holds the hamburger so it never overlaps a page title. The
                 gutter is wide enough (and the chrome inset ~24,28) to keep these edge-anchored
                 buttons clear of the TV title-unsafe / overscan band (~24x13.5 eff px at 200% scale);
                 they live OUTSIDE the page Frame's padding, so they need their own safe inset. -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Gutter: hamburger, then the games-in-progress tab just below it. (Back is the
                     gamepad B button — no on-screen back button needed.) -->
                <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="24,28,0,0" Spacing="10">
                    <Button x:Name="MenuButton" Click="ToggleNav_Click" Style="{StaticResource IconButton}"
                            Width="44" Height="44" CornerRadius="22" Background="#59000000"
                            FontFamily="Segoe MDL2 Assets" FontSize="18"
                            Content="&#xE700;" ToolTipService.ToolTip="Menu (Menu button)" />

                    <!-- Games in progress: pawn with an iOS-style count badge; opens the resume cards. -->
                    <Button x:Name="OngoingTab" Style="{StaticResource IconButton}" Visibility="Collapsed"
                            Width="44" Height="44" CornerRadius="22" Background="#59000000" HorizontalAlignment="Left"
                            ToolTipService.ToolTip="Games in progress">
                        <Grid>
                            <TextBlock Text="&#x265F;" FontFamily="Segoe UI Symbol" FontSize="24"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Border x:Name="OngoingBadge" MinWidth="18" Height="18" CornerRadius="9" Padding="4,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-9,-9,0"
                                    BorderBrush="#0E1207" BorderThickness="2"
                                    Background="{StaticResource AccentGreenLightBrush}">
                                <TextBlock x:Name="OngoingBadgeCount" Text="0" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#0E1207" />
                            </Border>
                        </Grid>
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <StackPanel Width="320" Spacing="10">
                                    <TextBlock Text="Continue playing" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentGreenLightBrush}" />
                                    <ItemsControl x:Name="OngoingList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource TileButton}" Padding="10" Margin="0,0,0,8"
                                                        HorizontalContentAlignment="Left" Tag="{Binding GameId}" Click="OngoingGame_Click">
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="72" Height="72" CornerRadius="8">
                                                            <controls:ChessBoardControl Fen="{Binding Fen}" WhiteAtBottom="{Binding WhiteAtBottom}"
                                                                                        Interactive="False" IsTabStop="False" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3" Margin="0,0,4,0">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="{StaticResource AccentGreenLightBrush}"
                                                                         Opacity="{Binding IsMyTurn, Converter={StaticResource BoolToOpacity}}" />
                                                                <TextBlock Text="{Binding OpponentName}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding TypeText}" FontSize="{StaticResource CaptionSize}" TextTrimming="CharacterEllipsis"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding TurnText}" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Incoming challenges: swords icon + count; opens Accept/Decline cards. Hidden on the
                         Play page, which shows its own real-time challenge banner. -->
                    <Button x:Name="ChallengeTab" Style="{StaticResource IconButton}" Visibility="Collapsed"
                            Width="44" Height="44" CornerRadius="22" Background="#59000000" HorizontalAlignment="Left"
                            ToolTipService.ToolTip="Incoming challenges">
                        <Grid>
                            <TextBlock Text="&#x2694;&#xFE0F;" FontFamily="Segoe UI Emoji" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border MinWidth="18" Height="18" CornerRadius="9" Padding="4,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-9,-9,0"
                                    BorderBrush="#0E1207" BorderThickness="2"
                                    Background="{StaticResource WarningBrush}">
                                <TextBlock x:Name="ChallengeBadgeCount" Text="0" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#0E1207" />
                            </Border>
                        </Grid>
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <StackPanel Width="320" Spacing="10">
                                    <TextBlock Text="Incoming challenges" FontSize="{StaticResource CaptionSize}" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentGreenLightBrush}" />
                                    <ItemsControl x:Name="ChallengeList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="12" Padding="12" Margin="0,0,0,8"
                                                        Background="{StaticResource AppSurfaceHighBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="{Binding ChallengerName}" FontSize="{StaticResource BodySize}" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Description}" FontSize="{StaticResource CaptionSize}" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Content="Accept" Padding="0,8"
                                                                    Tag="{Binding Id}" Click="AcceptChallenge_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                                            <Button Grid.Column="1" Style="{StaticResource TileButton}" Content="Decline" Padding="0,8"
                                                                    Tag="{Binding Id}" Click="DeclineChallenge_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <!-- MaxWidth caps the 4K@100% / ultrawide sprawl: a true no-op at <=1920 eff px
                     (normal Xbox 960 and maximized 1080p PC), it only stops fixed-width panels from
                     drifting apart on an oversized effective canvas. Stretch+MaxWidth centres when capped. -->
                <Frame x:Name="ContentFrame" Grid.Column="1" MaxWidth="1920" />

            </Grid>
        </SplitView>
    </Grid>
</Page>
