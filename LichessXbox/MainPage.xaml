<Page
    x:Class="LichessXbox.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="HeroGradientBrush" />
        </Grid.Background>

        <muxc:NavigationView x:Name="Nav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="280"
            Background="Transparent"
            SelectionChanged="Nav_SelectionChanged">

            <muxc:NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,16,8,8">
                    <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource AccentGradientBrush}">
                        <TextBlock Text="♞" FontFamily="Segoe UI Symbol" FontSize="30"
                                   Foreground="#0E1207" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="lichess" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="for Xbox" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </muxc:NavigationView.PaneHeader>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Home" Tag="home" Icon="Home" />
                <muxc:NavigationViewItem Content="Play" Tag="play" Icon="Play" />
                <muxc:NavigationViewItem Content="Watch" Tag="watch" Icon="Video" />
                <muxc:NavigationViewItem Content="Analysis" Tag="analysis">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE9D9;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Puzzles" Tag="puzzles">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE9F5;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Tournaments" Tag="tournaments">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xEE40;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Studies" Tag="studies">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE82D;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Games" Tag="games" Icon="AllApps" />
                <muxc:NavigationViewItem Content="Profile" Tag="profile" Icon="Contact" />
            </muxc:NavigationView.MenuItems>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem Content="Board editor" Tag="editor">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE70F;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Coordinates" Tag="coords">
                    <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE809;" /></muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Settings" Tag="settings" Icon="Setting" />
            </muxc:NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Margin="12,0,12,12" />
        </muxc:NavigationView>
    </Grid>
</Page>
